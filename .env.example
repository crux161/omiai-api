# Shared with Elixir gateway — MUST match OMIAI_JWT_SECRET on the gateway
JWT_SECRET=omiai_dev_jwt_secret_change_in_prod

# Elixir gateway base URL (for webhook callbacks)
GATEWAY_URL=http://localhost:4000

# API key the Python service sends when calling Elixir internal endpoints
# Must match OMIAI_INTERNAL_API_KEY on the gateway
GATEWAY_INTERNAL_KEY=omiai_dev_internal_key

# Database URL (SQLite default; swap for PostgreSQL in prod)
DATABASE_URL=sqlite+aiosqlite:///./omiai_api.db
